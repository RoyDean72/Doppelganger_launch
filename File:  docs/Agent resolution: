```yaml
name: Validate Environment

on:
  push:
    paths:
      - '.env.template'
      - 'src/**/.env.*'
      - 'docker/**/.env.*'
      - 'infra/terraform/.env.*'
  pull_request:
    branches: [main, develop]

jobs:
  validate-env:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Setup .NET
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: '8.0.x'
      
      - name: Validate Environment Templates
        run: |
          # Check all .env.* files are valid
          find . -name ".env.*" -type f ! -path "./.git/*" | while read file; do
            echo "Validating $file"
            # Ensure no actual secrets in templates
            if grep -E "(password|secret|key|token).*=.*[a-zA-Z0-9]{20,}" "$file"; then
              echo "ERROR: Potential secret in template $file"
              exit 1
            fi
          done
      
      - name: Check for Secrets in Code
        uses: trufflesecurity/trufflehog@main
        with:
          path: ./
          base: ${{ github.event.repository.default_branch }}
          head: HEAD
          extra_args: --debug --only-verified
      
      - name: Validate JSON Schemas
        run: |
          # Validate functions.json schema
          dotnet run --project src/Agent.CLI -- validate-schema \
            --schema .github/agents/dotnet-architect/functions.json
      
      - name: Test Environment Loading
        run: |
          cp .env.template .env
          # Set dummy values for required vars
          echo "AZURE_CLIENT_SECRET=dummy" >> .env
          echo "OPENAI_API_KEY=dummy" >> .env
          dotnet run --project src/Agent.CLI -- validate-env --dry-run

  check-dependencies:
    runs-on: ubuntu-latest
    needs: validate-env
    steps:
      - uses: actions/checkout@v4
      
      - name: Check Terraform Variables
        run: |
          cd infra/terraform
          terraform init -backend=false
          terraform validate
          terraform plan -var-file=environments/dev.tfvars -detailed-exitcode || true
      
      - name: Validate Docker Compose
        run: |
          cd docker
          docker-compose --env-file .env.docker-compose config > /dev/null
