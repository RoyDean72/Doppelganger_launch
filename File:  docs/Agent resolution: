#!/bin/bash
# scripts/rotate-azure-credentials.sh

set -e

SP_NAME="agent-service-principal"
KV_NAME="agent-prod-kv"

echo "Creating new secret..."
NEW_SECRET=$(az ad sp credential reset \
  --name $SP_NAME \
  --query password -o tsv)

echo "Updating Key Vault..."
az keyvault secret set \
  --vault-name $KV_NAME \
  --name AzureClientSecret \
  --value "$NEW_SECRET"

echo "Restarting services..."
az webapp restart --name agent-prod-api --resource-group agent-prod-rg

echo "Deleting old secret (manual step)..."
echo "Run: az ad sp credential list --name $SP_NAME"
echo "Then: az ad sp credential delete --name $SP_NAME --key-id <old-id>"
