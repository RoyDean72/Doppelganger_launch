# =============================================================================
# VS Code Environment Configuration
# Extension and editor settings for .NET Self-Learning Architect
# =============================================================================

# ------------------------------------------------------------------------------
# VS Code Agent Extension
# ------------------------------------------------------------------------------
VSCODE_AGENT_ENABLED=true
VSCODE_AGENT_AUTO_START=true
VSCODE_AGENT_PORT=9001
VSCODE_AGENT_HOST=localhost

# Extension behavior
VSCODE_AGENT_SHOW_STATUS_BAR=true
VSCODE_AGENT_AUTO_COMPLETE_FUNCTIONS=true
VSCODE_AGENT_VALIDATE_ON_SAVE=true

# ------------------------------------------------------------------------------
# Terminal Integration
# ------------------------------------------------------------------------------
VSCODE_TERMINAL_SHELL=/bin/bash
VSCODE_TERMINAL_TIMEOUT_SECONDS=300
VSCODE_TERMINAL_MAX_OUTPUT_LINES=10000

# Auto-run commands
VSCODE_TERMINAL_AUTO_ACTIVATE=true
VSCODE_TERMINAL_STARTUP_COMMAND=dotnet build

# ------------------------------------------------------------------------------
# File Watchers
# ------------------------------------------------------------------------------
VSCODE_WATCH_FUNCTIONS_JSON=true
VSCODE_WATCH_AGENT_CONFIG=true
VSCODE_HOT_RELOAD_ON_CHANGE=false

# Debounce settings
VSCODE_WATCH_DEBOUNCE_MS=500
VSCODE_WATCH_EXCLUDE=bin/**,obj/**,node_modules/**,.git/**

# ------------------------------------------------------------------------------
# IntelliSense & Validation
# ------------------------------------------------------------------------------
VSCODE_VALIDATE_JSON_SCHEMAS=true
VSCODE_VALIDATE_ON_TYPE=true
VSCODE_VALIDATE_DELAY_MS=300

# Function discovery
VSCODE_FUNCTION_DISCOVERY_PATH=./.github/agents/dotnet-architect/functions.json
VSCODE_SHOW_FUNCTION_SIGNATURES=true

# ------------------------------------------------------------------------------
# Debugging
# ------------------------------------------------------------------------------
VSCODE_DEBUG_PORT=9229
VSCODE_DEBUG_AUTO_ATTACH=false

# Agent debugging
VSCODE_AGENT_DEBUG_LOGGING=false
VSCODE_AGENT_TRACE_CALLS=false

# ------------------------------------------------------------------------------
# UI Preferences
# ------------------------------------------------------------------------------
VSCODE_THEME=Dark+
VSCODE_ICON_THEME=vs-seti

# Agent panel
VSCODE_AGENT_PANEL_POSITION=right
VSCODE_AGENT_PANEL_SIZE=300

# Output channels
VSCODE_AGENT_OUTPUT_VERBOSE=false
