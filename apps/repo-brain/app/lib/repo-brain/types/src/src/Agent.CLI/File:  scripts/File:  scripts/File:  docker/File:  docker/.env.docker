# Docker Compose specific overrides
# Used by docker-compose.yml and docker-compose.*.yml

# =============================================================================
# Services Configuration
# =============================================================================

# ------------------------------------------------------------------------------
# Agent Runtime Service
# ------------------------------------------------------------------------------
AGENT_RUNTIME_REPLICAS=1
AGENT_RUNTIME_RESTART_POLICY=unless-stopped

# Environment file path (inside container)
AGENT_RUNTIME_ENV_FILE=/app/.env

# ------------------------------------------------------------------------------
# Supporting Services
# ------------------------------------------------------------------------------

# Redis (for caching and pub/sub)
REDIS_ENABLED=true
REDIS_IMAGE=redis:7-alpine
REDIS_PORT=6379
REDIS_PASSWORD=

# PostgreSQL (alternative state storage)
POSTGRES_ENABLED=false
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_PORT=5432
POSTGRES_DB=agent_state
POSTGRES_USER=agent
POSTGRES_PASSWORD=changeme

# SQLite Web (for debugging state database)
SQLITE_WEB_ENABLED=false
SQLITE_WEB_PORT=8081

# OTLP Collector (for telemetry)
OTEL_COLLECTOR_ENABLED=true
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:latest
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318

# Jaeger (for distributed tracing)
JAEGER_ENABLED=true
JAEGER_IMAGE=jaegertracing/all-in-one:latest
JAEGER_UI_PORT=16686
JAEGER_OTLP_PORT=4317

# Prometheus (for metrics)
PROMETHEUS_ENABLED=true
PROMETHEUS_IMAGE=prom/prometheus:latest
PROMETHEUS_PORT=9090

# Grafana (for dashboards)
GRAFANA_ENABLED=true
GRAFANA_IMAGE=grafana/grafana:latest
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# ------------------------------------------------------------------------------
# Networks
# ------------------------------------------------------------------------------
DOCKER_NETWORK_NAME=agent-network
DOCKER_NETWORK_DRIVER=bridge

# ------------------------------------------------------------------------------
# Shared Volumes
# ------------------------------------------------------------------------------
VOLUME_AGENT_DATA=agent-data
VOLUME_AGENT_LOGS=agent-logs
VOLUME_AGENT_REPO=agent-repo
