# =============================================================================
# Docker Environment Configuration
# Container runtime settings for .NET Self-Learning Architect
# =============================================================================

# ------------------------------------------------------------------------------
# Container Runtime
# ------------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=dotnet-architect
COMPOSE_FILE=docker-compose.yml:docker-compose.override.yml

# Image configuration
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_NAME=dotnet-architect/agent
DOCKER_IMAGE_TAG=latest
DOCKER_BUILDKIT=1

# Container resources
CONTAINER_CPU_LIMIT=2
CONTAINER_MEMORY_LIMIT=4g
CONTAINER_MEMORY_RESERVATION=2g

# ------------------------------------------------------------------------------
# Agent Runtime (Container)
# ------------------------------------------------------------------------------
AGENT_INSTANCE_ID=docker-${HOSTNAME}
AGENT_ENVIRONMENT=Container
AGENT_WORKER_THREADS=4

# State persistence in container
STATE_STORAGE_TYPE=sqlite
STATE_DATABASE_PATH=/data/agent-state.db

# Log shipping
LOG_LEVEL=Information
LOG_FORMAT=json
LOG_OUTPUT=console
LOG_SHIP_TO_STDOUT=true

# ------------------------------------------------------------------------------
# Networking
# ------------------------------------------------------------------------------
AGENT_HTTP_PORT=8080
AGENT_HTTPS_PORT=8443
AGENT_GRPC_PORT=9090

# Service discovery
AGENT_SERVICE_NAME=dotnet-architect
AGENT_SERVICE_NAMESPACE=default

# ------------------------------------------------------------------------------
# Volume Mounts
# ------------------------------------------------------------------------------
# Host paths mounted into container
HOST_REPO_PATH=/repo
HOST_LOGS_PATH=/logs
HOST_DATA_PATH=/data

# Container paths
CONTAINER_REPO_PATH=/workspace
CONTAINER_LOGS_PATH=/var/log/agent
CONTAINER_DATA_PATH=/data

# ------------------------------------------------------------------------------
# Security (Container)
# ------------------------------------------------------------------------------
# Run as non-root
CONTAINER_USER_UID=1000
CONTAINER_USER_GID=1000

# Read-only root filesystem
CONTAINER_READ_ONLY_ROOTFS=true

# Security options
CONTAINER_NO_NEW_PRIVILEGES=true
CONTAINER_SECCOMP_PROFILE=default

# ------------------------------------------------------------------------------
# Health Checks
# ------------------------------------------------------------------------------
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_START_PERIOD=60s
HEALTH_CHECK_RETRIES=3

# ------------------------------------------------------------------------------
# Development (Docker)
# ------------------------------------------------------------------------------
# Hot reload for development
DEV_HOT_RELOAD=false
DEV_VOLUME_MOUNT_SOURCE=../src

# Debug container
DEV_DEBUG_PORT=9229
DEV_TRACE_AGENT=false
