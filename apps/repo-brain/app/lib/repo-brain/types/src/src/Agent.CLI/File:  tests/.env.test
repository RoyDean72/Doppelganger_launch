# =============================================================================
# Test Environment Configuration
# Isolated settings for unit and integration tests
# =============================================================================

AGENT_ENVIRONMENT=Testing
AGENT_INSTANCE_ID=test-runner-${RANDOM}

# Mock all external services
MOCK_MODEL_PROVIDERS=true
MOCK_AZURE_SERVICES=true
MOCK_GITHUB_API=true
MOCK_DOCKER=true

# Fast execution
AGENT_WORKER_THREADS=2
FUNCTION_TIMEOUT_ANALYZE_REQUIREMENTS=5
FUNCTION_TIMEOUT_PROPOSE_ARCHITECTURE=10

# In-memory state
STATE_STORAGE_TYPE=inmemory
STATE_DATABASE_PATH=

# Test output
LOG_LEVEL=Warning
LOG_FORMAT=console
TEST_OUTPUT_PATH=./TestResults

# Coverage
COVERAGE_ENABLED=true
COVERAGE_THRESHOLD=80
COVERAGE_FORMAT=cobertura,json

# Parallel test execution
TEST_PARALLELISM=true
TEST_MAX_PARALLEL_DEGREE=4
