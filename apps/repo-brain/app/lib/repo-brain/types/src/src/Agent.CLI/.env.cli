# CLI-specific environment configuration
# For command-line interface tool

AGENT_INSTANCE_ID=cli-session-${USER}
AGENT_ENVIRONMENT=Development

# Single-threaded for CLI
AGENT_WORKER_THREADS=1
AGENT_MAX_CONCURRENT_TASKS=1

# Interactive mode settings
CLI_INTERACTIVE_MODE=true
CLI_PROMPT_TIMEOUT_SECONDS=30
CLI_HISTORY_ENABLED=true
CLI_HISTORY_PATH=~/.dotnet-architect/history

# Output formatting
CLI_OUTPUT_FORMAT=rich
CLI_COLOR_ENABLED=true
CLI_PROGRESS_BARS=true

# Quiet mode for scripting
CLI_QUIET_MODE=false
