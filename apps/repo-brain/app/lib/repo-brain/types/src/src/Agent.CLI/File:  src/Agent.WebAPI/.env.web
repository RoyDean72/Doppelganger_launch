# Web API host environment configuration
# For ASP.NET Core hosting of agent services

AGENT_INSTANCE_ID=webapi-${HOSTNAME}
AGENT_ENVIRONMENT=Staging

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Staging
ASPNETCORE_URLS=http://localhost:5000;https://localhost:5001
ASPNETCORE_KESTREL_CERTIFICATE_PATH=/etc/ssl/certs/agent.pfx

# API security
API_AUTH_ENABLED=true
API_AUTH_SCHEME=Bearer
API_AUTH_AUTHORITY=https://login.microsoftonline.com/${AZURE_TENANT_ID}
API_AUTH_AUDIENCE=api://dotnet-architect

# Rate limiting
API_RATE_LIMIT_REQUESTS_PER_MINUTE=60
API_RATE_LIMIT_BURST=10

# Request handling
API_MAX_REQUEST_SIZE_MB=50
API_REQUEST_TIMEOUT_SECONDS=300

# Health checks
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_ENDPOINT=/health
HEALTH_CHECK_INTERVAL_SECONDS=30
