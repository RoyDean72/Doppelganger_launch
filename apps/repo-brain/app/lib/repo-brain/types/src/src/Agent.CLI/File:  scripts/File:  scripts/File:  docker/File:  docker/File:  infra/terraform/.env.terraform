# =============================================================================
# Terraform Environment Configuration
# Infrastructure as Code for .NET Self-Learning Architect
# =============================================================================

# ------------------------------------------------------------------------------
# Terraform Core
# ------------------------------------------------------------------------------
TF_LOG=INFO
TF_LOG_PATH=./terraform.log
TF_INPUT=false
TF_IN_AUTOMATION=true

# Plugin cache
TF_PLUGIN_CACHE_DIR=~/.terraform.d/plugin-cache

# State backend
TF_BACKEND_TYPE=azurerm
TF_BACKEND_RESOURCE_GROUP_NAME=terraform-state-rg
TF_BACKEND_STORAGE_ACCOUNT_NAME=tfstateagent
TF_BACKEND_CONTAINER_NAME=tfstate
TF_BACKEND_KEY=agent.infra.tfstate

# ------------------------------------------------------------------------------
# Azure Provider
# ------------------------------------------------------------------------------
ARM_SUBSCRIPTION_ID=${AZURE_SUBSCRIPTION_ID}
ARM_TENANT_ID=${AZURE_TENANT_ID}
ARM_CLIENT_ID=${AZURE_CLIENT_ID}
ARM_CLIENT_SECRET=${AZURE_CLIENT_SECRET}
ARM_ENVIRONMENT=public

# Azure features
ARM_SKIP_PROVIDER_REGISTRATION=false
ARM_STORAGE_USE_AZUREAD=true

# ------------------------------------------------------------------------------
# Deployment Environment
# ------------------------------------------------------------------------------
# These map to terraform workspaces
DEPLOYMENT_ENVIRONMENT=dev
DEPLOYMENT_LOCATION=eastus
DEPLOYMENT_PREFIX=agent

# Resource naming
RESOURCE_GROUP_NAME=${DEPLOYMENT_PREFIX}-${DEPLOYMENT_ENVIRONMENT}-rg
APP_SERVICE_PLAN_NAME=${DEPLOYMENT_PREFIX}-${DEPLOYMENT_ENVIRONMENT}-plan
WEB_APP_NAME=${DEPLOYMENT_PREFIX}-${DEPLOYMENT_ENVIRONMENT}-api
FUNCTION_APP_NAME=${DEPLOYMENT_PREFIX}-${DEPLOYMENT_ENVIRONMENT}-functions
CONTAINER_REGISTRY_NAME=${DEPLOYMENT_PREFIX}${DEPLOYMENT_ENVIRONMENT}acr

# ------------------------------------------------------------------------------
# Agent Application Settings (Terraform)
# ------------------------------------------------------------------------------
TF_VAR_agent_runtime_version=1.0.0
TF_VAR_agent_environment=${DEPLOYMENT_ENVIRONMENT}
TF_VAR_agent_log_level=Information
TF_VAR_agent_learning_enabled=true

# Model provider keys (passed to Key Vault, not hardcoded)
TF_VAR_openai_api_key=${OPENAI_API_KEY}
TF_VAR_anthropic_api_key=${ANTHROPIC_API_KEY}

# ------------------------------------------------------------------------------
# Feature Flags (Infrastructure)
# ------------------------------------------------------------------------------
TF_VAR_enable_redis_cache=true
TF_VAR_enable_application_insights=true
TF_VAR_enable_key_vault=true
TF_VAR_enable_managed_identity=true

# Scaling
TF_VAR_app_service_sku_tier=Standard
TF_VAR_app_service_sku_size=S1
TF_VAR_app_service_min_instances=1
TF_VAR_app_service_max_instances=3

# ------------------------------------------------------------------------------
# Networking
# ------------------------------------------------------------------------------
TF_VAR_vnet_enabled=false
TF_VAR_vnet_address_space=10.0.0.0/16
TF_VAR_subnet_agent_prefix=10.0.1.0/24
TF_VAR_subnet_db_prefix=10.0.2.0/24

# Private endpoints
TF_VAR_private_endpoint_enabled=false

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
TF_VAR_database_type=postgresql
TF_VAR_database_sku_name=B_Gen5_1
TF_VAR_database_storage_mb=5120
TF_VAR_database_backup_retention_days=7

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
TF_VAR_enable_ddos_protection=false
TF_VAR_enable_waf=false
TF_VAR_waf_mode=Detection

# TLS
TF_VAR_min_tls_version=1.2

# ------------------------------------------------------------------------------
# Monitoring
# ------------------------------------------------------------------------------
TF_VAR_log_analytics_workspace_name=${DEPLOYMENT_PREFIX}-${DEPLOYMENT_ENVIRONMENT}-logs
TF_VAR_log_retention_days=30
TF_VAR_app_insights_retention_days=90

# Alerts
TF_VAR_enable_budget_alert=true
TF_VAR_budget_amount=1000
TF_VAR_budget_alert_threshold=80

# ------------------------------------------------------------------------------
# Tags (Applied to all resources)
# ------------------------------------------------------------------------------
TF_VAR_tags='{
  "Project": "dotnet-self-learning-architect",
  "Environment": "${DEPLOYMENT_ENVIRONMENT}",
  "ManagedBy": "Terraform",
  "CostCenter": "engineering",
  "DataClassification": "internal"
}'
