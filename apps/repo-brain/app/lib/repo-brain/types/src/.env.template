# =============================================================================
# .NET Self-Learning Architect - Source Code Environment
# Runtime configuration for agent execution engine
# =============================================================================

# ------------------------------------------------------------------------------
# Core Agent Runtime
# ------------------------------------------------------------------------------
AGENT_RUNTIME_VERSION=1.0.0
AGENT_INSTANCE_ID=architect-local-001

# Execution mode: Development, Staging, Production
AGENT_ENVIRONMENT=Development

# Host process configuration
AGENT_WORKER_THREADS=4
AGENT_MAX_CONCURRENT_TASKS=10
AGENT_TASK_QUEUE_SIZE=100

# ------------------------------------------------------------------------------
# Model Provider APIs
# ------------------------------------------------------------------------------
# Primary model endpoint (GPT-5.3-Codex)
PRIMARY_MODEL_ENDPOINT=https://api.openai.com/v1
PRIMARY_MODEL_API_KEY=${OPENAI_API_KEY}
PRIMARY_MODEL_NAME=gpt-5.3-codex
PRIMARY_MODEL_TIMEOUT_SECONDS=120

# Copilot model endpoints (Claude family)
COPILOT_MODEL_ENDPOINT=https://api.anthropic.com/v1
COPILOT_MODEL_API_KEY=${ANTHROPIC_API_KEY}
COPILOT_MODEL_SONNET=claude-sonnet-4.6
COPILOT_MODEL_OPUS=claude-opus-4.6
COPILOT_MODEL_HAIKU=claude-haiku-4.5

# Fallback model (used if primary fails)
FALLBACK_MODEL_NAME=gpt-4-turbo
FALLBACK_MODEL_TIMEOUT_SECONDS=60

# ------------------------------------------------------------------------------
# Function Registry
# ------------------------------------------------------------------------------
FUNCTIONS_SCHEMA_PATH=./functions.json
FUNCTIONS_VALIDATE_ON_LOAD=true
FUNCTIONS_HOT_RELOAD=false

# Function execution timeouts (seconds)
FUNCTION_TIMEOUT_ANALYZE_REQUIREMENTS=30
FUNCTION_TIMEOUT_PROPOSE_ARCHITECTURE=60
FUNCTION_TIMEOUT_SPAWN_SUBAGENT=300
FUNCTION_TIMEOUT_RECORD_LESSON=10
FUNCTION_TIMEOUT_RUN_INCREMENTAL_CHECK=300

# ------------------------------------------------------------------------------
# Subagent Orchestration
# ------------------------------------------------------------------------------
SUBAGENT_CONTRACTS_PATH=./subagent-contracts
SUBAGENT_MAX_RETRY_ATTEMPTS=3
SUBAGENT_RETRY_BACKOFF_SECONDS=5

# Parallel mode limits
PARALLEL_MAX_SUBAGENTS=5
PARALLEL_TIMEOUT_MINUTES=30

# Orchestration mode settings
ORCHESTRATION_PHASE_TIMEOUT_MINUTES=60
ORCHESTRATION_GATE_TIMEOUT_MINUTES=15

# ------------------------------------------------------------------------------
# Self-Learning Engine
# ------------------------------------------------------------------------------
LEARNING_ENGINE_ENABLED=true
LEARNING_ENGINE_MODE=active

# Pattern storage
PATTERN_STORAGE_TYPE=filesystem
PATTERN_STORAGE_PATH=../../.github

# Deduplication service
DEDUPE_SERVICE_ENABLED=true
DEDUPE_SIMILARITY_THRESHOLD=0.75
DEDUPE_EMBEDDING_MODEL=text-embedding-3-small

# Conflict resolution
CONFLICT_RESOLUTION_AUTO=false
CONFLICT_RESOLUTION_NOTIFY_USER=true

# ------------------------------------------------------------------------------
# State Management
# ------------------------------------------------------------------------------
STATE_STORAGE_TYPE=sqlite
STATE_DATABASE_PATH=./data/agent-state.db
STATE_BACKUP_ENABLED=true
STATE_BACKUP_INTERVAL_MINUTES=15

# Session persistence
SESSION_TIMEOUT_MINUTES=120
SESSION_AUTO_SAVE=true

# ------------------------------------------------------------------------------
# Tool Integrations
# ------------------------------------------------------------------------------
# VS Code integration
VSCODE_API_PORT=9001
VSCODE_API_ENABLED=true
VSCODE_EXTENSION_ID=dotnet-architect.agent

# Terminal execution
TERMINAL_SHELL=/bin/bash
TERMINAL_TIMEOUT_SECONDS=300
TERMINAL_MAX_OUTPUT_LINES=10000

# File system operations
FILE_OPS_MAX_SIZE_MB=10
FILE_OPS_ALLOWED_EXTENSIONS=.cs,.json,.md,.yml,.yaml,.xml,.csproj,.sln,.dockerfile
FILE_OPS_BLOCKED_PATHS=bin/,obj/,node_modules/,secrets/

# ------------------------------------------------------------------------------
# Validation & Testing
# ------------------------------------------------------------------------------
VALIDATION_COMPILATION_ENABLED=true
VALIDATION_TEST_FRAMEWORK=xunit
VALIDATION_COVERAGE_TOOL=coverlet

# Security scanning
SECURITY_SCAN_SECRETS=true
SECURITY_SCAN_DEPENDENCIES=true
SECURITY_SCAN_SAST=false

# ------------------------------------------------------------------------------
# Telemetry & Observability
# ------------------------------------------------------------------------------
TELEMETRY_ENABLED=true
TELEMETRY_ENDPOINT=https://telemetry.internal.company.com
TELEMETRY_SAMPLING_RATE=0.1

# Logging
LOG_LEVEL=Information
LOG_FORMAT=json
LOG_OUTPUT=console,file
LOG_FILE_PATH=./logs/agent-runtime.log
LOG_MAX_SIZE_MB=100
LOG_MAX_FILES=10

# Distributed tracing
TRACING_ENABLED=true
TRACING_EXPORTER=otlp
TRACING_OTLP_ENDPOINT=http://localhost:4317

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_ENDPOINT=/metrics

# ------------------------------------------------------------------------------
# External Services
# ------------------------------------------------------------------------------
# Azure SDK configuration
AZURE_SDK_LOG_LEVEL=warning
AZURE_IDENTITY_TYPE=service-principal

# GitHub API
GITHUB_API_VERSION=2022-11-28
GITHUB_API_TIMEOUT_SECONDS=30
GITHUB_API_RETRY_COUNT=3

# NuGet/Package management
NUGET_RESTORE_ENABLED=true
NUGET_CACHE_PATH=./.nuget/packages

# Docker
DOCKER_REGISTRY=https://registry.hub.docker.com
DOCKER_BUILDKIT_ENABLED=true

# ------------------------------------------------------------------------------
# Feature Flags (Runtime)
# ------------------------------------------------------------------------------
FEATURE_ADVANCED_ORCHESTRATION=true
FEATURE_PREDICTIVE_SCALING=false
FEATURE_AUTO_REMEDIATION=false
FEATURE_EXPERIMENTAL_TOOLS=false

# ------------------------------------------------------------------------------
# Development Settings
# ------------------------------------------------------------------------------
DEV_MODE_MOCK_MODELS=false
DEV_MODE_FAST_FAILURE=true
DEV_MODE_TRACE_ALL_CALLS=true

# Hot reload for function schemas
DEV_HOT_RELOAD_FUNCTIONS=false
DEV_HOT_RELOAD_INTERVAL_SECONDS=5

# Debug settings
DEBUG_BREAK_ON_ERROR=false
DEBUG_DUMP_STATE_ON_FAILURE=true
DEBUG_KEEP_TEMP_FILES=false
