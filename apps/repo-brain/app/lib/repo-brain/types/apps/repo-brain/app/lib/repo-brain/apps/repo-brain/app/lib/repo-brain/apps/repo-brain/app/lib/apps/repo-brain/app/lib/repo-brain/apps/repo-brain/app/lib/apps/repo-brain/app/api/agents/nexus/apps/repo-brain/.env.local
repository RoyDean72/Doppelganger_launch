# Mistral API Configuration
# Get this from console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# Agent IDs from Mistral Agent Builder
# These look like: ag:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXUS_AGENT_ID=your_nexus_agent_id_here
DNA_SCANNER_AGENT_ID=your_dna_scanner_agent_id_here

# Optional: Other agents (can leave blank for now)
PAYMENT_GEM_AGENT_ID=
TTR_CALCULATOR_AGENT_ID=

# Security
# Generate a random string: openssl rand -hex 32
GEM_SIGNATURE_SALT=your_random_salt_here

# Optional: Stripe for billing
STRIPE_SECRET_KEY=
